---
import '../styles/global.css';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="登录 - SmartHealth" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>登录 | SmartHealth</title>
  </head>
  <body class="min-h-screen font-pixel flex items-center justify-center p-4">
    <!-- Animated Background -->
    <div class="fixed inset-0 w-full h-full overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-10 left-10 w-4 h-4 bg-[#ff6b9d] animate-pixel-pulse"></div>
      <div class="absolute top-20 right-20 w-3 h-3 bg-[#4ecdc4] animate-pixel-pulse" style="animation-delay: 0.3s"></div>
      <div class="absolute bottom-10 left-20 w-2 h-2 bg-[#ffe66d] animate-pixel-pulse" style="animation-delay: 0.6s"></div>
      <div class="absolute bottom-20 right-10 w-3 h-3 bg-[#a8e6cf] animate-pixel-pulse" style="animation-delay: 0.9s"></div>
      <div class="absolute top-1/4 left-1/3 w-2 h-2 bg-[#ff6b9d] animate-pixel-pulse" style="animation-delay: 1.2s"></div>
      <div class="absolute bottom-1/4 right-1/3 w-2 h-2 bg-[#4ecdc4] animate-pixel-pulse" style="animation-delay: 1.5s"></div>
    </div>

    <main class="w-full max-w-md relative z-10">
      <!-- Logo Section -->
      <div class="text-center mb-8">
        <div class="inline-block">
          <div class="text-6xl md:text-7xl mb-4 animate-pixel-float">🎮</div>
          <h1 class="text-3xl md:text-4xl text-pixel-gradient font-bold leading-tight">
            SMART HEALTH
          </h1>
        </div>
        <p class="text-sm text-[#4ecdc4] uppercase tracking-[0.2em] mt-4">
          ▶ 个人健康管理系统 ◀
        </p>
      </div>

      <!-- Login Card -->
      <div class="pixel-card p-8">
        <div class="text-center mb-8">
          <div class="inline-flex items-center gap-2 mb-2">
            <span class="text-2xl">🔐</span>
            <h2 class="text-xl text-[#ff6b9d] uppercase tracking-wider">玩家登录</h2>
          </div>
          <p class="text-xs text-[#5a5a8a]">输入您的凭证开始游戏</p>
        </div>

        <form class="space-y-6" id="login-form">
          <div>
            <label class="block text-xs text-[#4ecdc4] uppercase tracking-wider mb-3">
              📧 邮箱地址
            </label>
            <input
              type="email"
              name="email"
              class="pixel-input"
              placeholder="player@example.com"
              required
            />
          </div>

          <div>
            <label class="block text-xs text-[#4ecdc4] uppercase tracking-wider mb-3">
              🔑 密码
            </label>
            <input
              type="password"
              name="password"
              class="pixel-input"
              placeholder="•••••••••"
              required
            />
          </div>

          <button type="submit" class="pixel-btn w-full">
            ▶ 开始游戏
          </button>
        </form>

        <div class="mt-8 text-center">
          <p class="text-xs text-[#5a5a8a] mb-4">
            ── 或者 ──
          </p>
          <div class="flex gap-4 justify-center">
            <button class="pixel-btn pixel-btn-secondary text-xs py-2 px-4">
              🎮 微信登录
            </button>
            <button class="pixel-btn pixel-btn-accent text-xs py-2 px-4">
              📱 QQ登录
            </button>
          </div>
        </div>

        <div class="mt-8 text-center">
          <p class="text-xs text-[#5a5a8a]">
            还没有账号？
            <a href="/register" class="text-[#ff6b9d] hover:text-[#ffe66d] transition-colors underline">
              创建新账号
            </a>
          </p>
        </div>
      </div>

      <!-- Footer -->
      <div class="text-center mt-8">
        <p class="text-xs text-[#5a5a8a] uppercase tracking-wider">
          Pixel Art Edition v1.0.0
        </p>
      </div>
    </main>
  </body>
</html>
