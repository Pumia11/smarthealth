---
import '../../styles/global.css';
import PixelCard from '../../components/PixelCard.astro';
import HealthRecords from '../../components/HealthRecords';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="健康指标 - SmartHealth" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>健康指标 | SmartHealth</title>
  </head>
  <body class="min-h-screen font-pixel overflow-x-hidden">
    <!-- Animated Background -->
    <div class="fixed inset-0 w-full h-full overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-10 left-10 w-4 h-4 bg-[#ff6b9d] animate-pixel-pulse"></div>
      <div class="absolute top-20 right-20 w-3 h-3 bg-[#4ecdc4] animate-pixel-pulse" style="animation-delay: 0.3s"></div>
      <div class="absolute top-30 left-1/4 w-2 h-2 bg-[#ffe66d] animate-pixel-pulse" style="animation-delay: 0.6s"></div>
      <div class="absolute bottom-10 right-10 w-3 h-3 bg-[#a8e6cf] animate-pixel-pulse" style="animation-delay: 0.9s"></div>
      <div class="absolute bottom-20 right-20 w-4 h-4 bg-[#ff6b9d] animate-pixel-pulse" style="animation-delay: 1.2s"></div>
      <div class="absolute bottom-30 left-20 w-2 h-2 bg-[#4ecdc4] animate-pixel-pulse" style="animation-delay: 1.5s"></div>
    </div>

    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-[#0f0f23]/95 backdrop-blur-sm border-b-4 border-[#3d3d6b]">
      <div class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
        <div class="flex items-center gap-4">
          <div class="text-3xl animate-pixel-float">❤️</div>
          <span class="text-xl md:text-2xl text-pixel-gradient font-bold tracking-wider">
            SMART HEALTH
          </span>
        </div>
        <nav class="hidden md:flex items-center gap-6">
          <a href="/" class="text-xs text-[#ccccdc] hover:text-[#ff6b9d] transition-colors px-3 py-2 border-b-2 border-transparent hover:border-[#ff6b9d]">首页</a>
          <a href="/health" class="text-xs text-[#ff6b9d] border-b-2 border-[#ff6b9d] px-3 py-2">健康</a>
          <a href="/diet" class="text-xs text-[#ccccdc] hover:text-[#ff6b9d] transition-colors px-3 py-2 border-b-2 border-transparent hover:border-[#ff6b9d]">饮食</a>
          <a href="/exercise" class="text-xs text-[#ccccdc] hover:text-[#ff6b9d] transition-colors px-3 py-2 border-b-2 border-transparent hover:border-[#ff6b9d]">运动</a>
          <a href="/ai" class="text-xs text-[#ccccdc] hover:text-[#ff6b9d] transition-colors px-3 py-2 border-b-2 border-transparent hover:border-[#ff6b9d]">AI分析</a>
        </nav>
        <a href="/login" class="pixel-btn text-xs py-2">
          登录
        </a>
      </div>
    </header>

    <!-- Main Content -->
    <main class="pt-24 pb-12 px-4 md:px-8">
      <div class="max-w-7xl mx-auto">
        <!-- Hero Section -->
        <section class="text-center mb-12">
          <div class="inline-block mb-6">
            <div class="text-6xl md:text-8xl mb-4 animate-pixel-float">📊</div>
            <h1 class="text-3xl md:text-5xl text-pixel-gradient font-bold leading-tight">
              健康指标
            </h1>
          </div>
          <p class="text-sm md:text-base text-[#4ecdc4] uppercase tracking-[0.3em] mb-8">
            ✨ 记录和追踪您的健康数据 ✨
          </p>
        </section>

        <!-- Stats Grid -->
        <section class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 mb-12">
          <div class="pixel-stat-box pixel-glow-pink">
            <div class="text-4xl mb-2">⚖️</div>
            <div class="text-2xl md:text-3xl text-[#ff6b9d] font-bold mb-1">65</div>
            <div class="text-xs text-[#5a5a8a] uppercase tracking-wider">体重</div>
          </div>
          <div class="pixel-stat-box pixel-glow-cyan">
            <div class="text-4xl mb-2">📏</div>
            <div class="text-2xl md:text-3xl text-[#4ecdc4] font-bold mb-1">170</div>
            <div class="text-xs text-[#5a5a8a] uppercase tracking-wider">身高</div>
          </div>
          <div class="pixel-stat-box">
            <div class="text-4xl mb-2">❤️</div>
            <div class="text-2xl md:text-3xl text-[#ffe66d] font-bold mb-1">72</div>
            <div class="text-xs text-[#5a5a8a] uppercase tracking-wider">心率</div>
          </div>
          <div class="pixel-stat-box">
            <div class="text-4xl mb-2">🌡️</div>
            <div class="text-2xl md:text-3xl text-[#a8e6cf] font-bold mb-1">36.5</div>
            <div class="text-xs text-[#5a5a8a] uppercase tracking-wider">体温</div>
          </div>
        </section>

        <!-- Health Records -->
        <section class="mb-12">
          <div class="flex justify-between items-center mb-6">
            <h2 class="pixel-title">📋 匨康记录</h2>
            <button class="pixel-btn text-xs py-2">
              + 添加记录
            </button>
          </div>
          <PixelCard class="p-6">
            <HealthRecords client:load />
          </PixelCard>
        </section>

        <!-- Indicator Categories -->
        <section class="mb-12">
          <h2 class="pixel-title text-center mb-6">📁 指标分类</h2>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            <a href="#" class="pixel-box pixel-box-hover p-4 text-center">
              <div class="text-3xl mb-2">🩸</div>
              <div class="text-sm text-[#ff6b9d]">血糖指标</div>
            </a>
            <a href="#" class="pixel-box pixel-box-hover p-4 text-center">
              <div class="text-3xl mb-2">📏</div>
              <div class="text-sm text-[#4ecdc4]">基础体征</div>
            </a>
            <a href="#" class="pixel-box pixel-box-hover p-4 text-center">
              <div class="text-3xl mb-2">❤️</div>
              <div class="text-sm text-[#ffe66d]">血压指标</div>
            </a>
            <a href="#" class="pixel-box pixel-box-hover p-4 text-center">
              <div class="text-3xl mb-2">💓</div>
              <div class="text-sm text-[#a8e6cf]">心率指标</div>
            </a>
            <a href="#" class="pixel-box pixel-box-hover p-4 text-center">
              <div class="text-3xl mb-2">🌡️</div>
              <div class="text-sm text-[#ff6b9d]">体温指标</div>
            </a>
          </div>
        </section>

        <!-- Back to Home -->
        <div class="mt-8">
          <a href="/" class="inline-flex items-center gap-2 text-xs text-[#5a5a8a] hover:text-[#ff6b9d] transition-colors">
            <span>←</span>
            <span>返回首页</span>
          </a>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer class="text-center py-8 border-t-4 border-[#3d3d6b]">
      <div class="text-xs text-[#5a5a8a] uppercase tracking-wider">
        Pixel Art Edition v1.0.0 | Made with ❤️
      </div>
    </footer>
  </body>
</html>
